GEMINI_API_KEY=your_gemini_api_key_here

# Audio caching — set to false to force regeneration on every request
AUDIO_CACHE=true

# OpenTelemetry Tracing
OTEL_ENABLED=true
OTEL_SERVICE_NAME=playback-iq

# Local Trace Exporter (Jaeger)
TRACE_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Remote Trace Exporter (Google Cloud Trace)
# TRACE_EXPORTER=gcp
# GOOGLE_CLOUD_PROJECT=change-me